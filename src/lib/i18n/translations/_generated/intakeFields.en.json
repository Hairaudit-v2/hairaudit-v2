{
  "clinic_name": {
    "prompt": "Clinic Name",
    "placeholder": "ABC Hair Clinic"
  },
  "clinic_country": {
    "prompt": "Clinic Country"
  },
  "clinic_country_other": {
    "prompt": "Clinic country (if Other)",
    "placeholder": "e.g. Portugal"
  },
  "clinic_city": {
    "prompt": "Clinic City",
    "placeholder": "Istanbul"
  },
  "procedure_date": {
    "prompt": "Date of Procedure"
  },
  "procedure_type": {
    "prompt": "Type of Procedure",
    "help": "Choose what you were told; 'Not Sure' is okay."
  },
  "procedure_type_other": {
    "prompt": "Procedure type (if Other)",
    "placeholder": "e.g. Combined"
  },
  "surgeon_name": {
    "prompt": "Surgeon's Name (optional)",
    "placeholder": "Dr. Smith"
  },
  "patient_name": {
    "prompt": "Your Name (optional, for privacy)",
    "placeholder": "John Doe"
  },
  "preop_consult": {
    "prompt": "Did you have a pre-operative consultation?"
  },
  "doctor_present_extraction": {
    "prompt": "Was a doctor present during graft extraction?",
    "options": {
      "yes": "Yes",
      "no": "No",
      "not_sure": "Not Sure"
    }
  },
  "doctor_present_implant": {
    "prompt": "Was a doctor present during graft implantation?",
    "options": {
      "yes": "Yes",
      "no": "No",
      "not_sure": "Not Sure"
    }
  },
  "graft_number_disclosed": {
    "prompt": "Were you told the graft count?"
  },
  "graft_number_received": {
    "prompt": "Graft number (if you were given one)",
    "help": "Only if you were given a number.",
    "placeholder": "e.g. 3500"
  },
  "donor_shaving": {
    "prompt": "Donor area shaving"
  },
  "surgery_duration": {
    "prompt": "Surgery duration"
  },
  "total_paid_currency": {
    "prompt": "Currency",
    "options": {
      "usd": "USD ($)",
      "eur": "EUR (€)",
      "gbp": "GBP (£)",
      "try": "TRY (₺)",
      "inr": "INR (₹)",
      "thb": "THB (฿)",
      "mxn": "MXN ($)",
      "aud": "AUD ($)",
      "other": "Other"
    }
  },
  "total_paid_currency_other": {
    "prompt": "Currency (if Other)",
    "placeholder": "e.g. CAD, CHF"
  },
  "total_paid_amount": {
    "prompt": "Total Amount Paid",
    "placeholder": "5000"
  },
  "cost_model": {
    "prompt": "How was the cost structured?",
    "options": {
      "per_graft": "Per graft",
      "per_session": "Per session",
      "package": "Package",
      "not_clear": "Not clear"
    }
  },
  "what_included": {
    "prompt": "What was included?",
    "options": {
      "procedure": "Procedure",
      "medications": "Medications",
      "followup": "Follow-up",
      "prp": "PRP",
      "accommodation": "Accommodation",
      "transport": "Transport",
      "other": "Other"
    }
  },
  "what_included_other": {
    "prompt": "Other inclusions (please specify)"
  },
  "pain_level": {
    "prompt": "Pain level during surgery",
    "help": "1 = No pain, 10 = Severe pain"
  },
  "post_op_swelling": {
    "prompt": "Post-operative swelling"
  },
  "bleeding_issue": {
    "prompt": "Any significant bleeding?"
  },
  "recovery_time": {
    "prompt": "Recovery time"
  },
  "shock_loss": {
    "prompt": "Did you experience shock loss (temporary shedding)?"
