          "No": "No",
          "Ongoing": "En curso",
          "Resolved": "Resuelta"
        }
      },
      "current_satisfaction": {
        "prompt": "Satisfacción actual (0–10)",
        "placeholder": "p. ej., 7"
      },
      "biggest_concern_now": {
        "prompt": "Principal preocupación ahora (opcional)",
