          "None": "Ninguna",
          "Mild": "Leve",
          "Moderate": "Moderada",
          "Significant": "Importante"
        }
      },
      "uneven_growth_present": {
        "prompt": "¿Crecimiento irregular? (opcional)"
      },
      "persistent_redness": {
        "prompt": "¿Enrojecimiento persistente? (opcional)"
      },
      "recipient_irregularities": {
        "prompt": "Irregularidades en zona receptora (opcional)",
