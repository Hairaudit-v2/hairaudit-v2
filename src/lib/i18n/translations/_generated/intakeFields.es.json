          "Ridges": "Surcos / cordones",
          "None": "Ninguna",
          "Not sure": "No estoy seguro/a"
        }
      }
    },
    "aesthetics": {
      "hairline_height_changed_cm": {
        "prompt": "Cambio de altura de la línea frontal (cm, opcional)",
        "placeholder": "p. ej., 1,5"
      },
      "temple_points_reconstructed": {
        "prompt": "¿Reconstruyeron las puntas temporales? (opcional)"
      },
      "direction_matches_native": {
        "prompt": "¿La dirección del pelo coincide con el pelo nativo? (opcional)",
        "options": {
          "Yes": "Sí",
          "Slight mismatch": "Ligeramente distinta",
          "No": "No",
          "Not sure": "No estoy seguro/a"
        }
      },
      "crown_swirl_matches": {
        "prompt": "¿El remolino de la coronilla luce natural? (opcional)",
        "options": {
          "Yes": "Sí",
          "No": "No",
          "Not applicable": "No aplica"
        }
      }
    },
    "experience": {
      "communication_rating": {
        "prompt": "Valoración de la comunicación"
      },
      "transparency_rating": {
        "prompt": "Valoración de la transparencia"
      },
      "felt_rushed": {
        "prompt": "¿Se sintió apresurado/a? (opcional)"
      },
      "felt_informed": {
        "prompt": "¿Se sintió bien informado/a?",
