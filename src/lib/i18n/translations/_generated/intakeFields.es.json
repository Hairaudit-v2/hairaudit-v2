          "None": "Ninguna",
          "Mild": "Leve",
          "Moderate": "Moderada",
          "Heavy": "Marcada"
        }
      },
      "regrowth_start_month": {
        "prompt": "Inicio del nuevo crecimiento visible (mes, opcional)",
