{
  "clinic_name": {
    "prompt": "Nombre de la clínica",
    "placeholder": "p. ej., Clínica Capilar Central"
  },
  "clinic_country": {
    "prompt": "País de la clínica"
  },
  "clinic_country_other": {
    "prompt": "País de la clínica (si eligió «Otro»)",
    "placeholder": "p. ej., Portugal"
  },
  "clinic_city": {
    "prompt": "Ciudad de la clínica",
    "placeholder": "p. ej., Estambul"
  },
  "procedure_date": {
    "prompt": "Fecha del procedimiento"
  },
  "procedure_type": {
    "prompt": "Tipo de procedimiento",
    "help": "Seleccione lo que le indicaron; «No estoy seguro/a» es una respuesta válida."
  },
  "procedure_type_other": {
    "prompt": "Tipo de procedimiento (si eligió «Otro»)",
    "placeholder": "p. ej., combinado FUE + DHI"
  },
  "surgeon_name": {
    "prompt": "Nombre del cirujano (opcional)",
    "placeholder": "p. ej., Dr. García"
  },
  "patient_name": {
    "prompt": "Su nombre (opcional, por privacidad)",
    "placeholder": "p. ej., A. M."
  },
  "preop_consult": {
    "prompt": "¿Tuvo consulta preoperatoria?"
  },
  "doctor_present_extraction": {
    "prompt": "¿Hubo un médico presente durante la extracción de injertos?",
    "options": {
      "yes": "Sí",
      "no": "No",
      "not_sure": "No estoy seguro/a"
    }
  },
  "doctor_present_implant": {
    "prompt": "¿Hubo un médico presente durante la implantación de injertos?",
    "options": {
      "yes": "Sí",
      "no": "No",
      "not_sure": "No estoy seguro/a"
    }
  },
  "graft_number_disclosed": {
    "prompt": "¿Le indicaron el número de injertos?"
  },
  "graft_number_received": {
    "prompt": "Número de injertos (si se lo comunicaron)",
    "help": "Rellene solo si le dieron una cifra concreta.",
    "placeholder": "p. ej., 3500"
  },
  "donor_shaving": {
    "prompt": "Afeitado en zona donante"
  },
  "surgery_duration": {
    "prompt": "Duración de la intervención"
  },
  "total_paid_currency": {
    "prompt": "Moneda",
    "options": {
      "usd": "USD ($)",
      "eur": "EUR (€)",
      "gbp": "GBP (£)",
      "try": "TRY (₺)",
      "inr": "INR (₹)",
      "thb": "THB (฿)",
      "mxn": "MXN ($)",
      "aud": "AUD ($)",
      "other": "Otra"
    }
  },
  "total_paid_currency_other": {
    "prompt": "Moneda (si eligió «Otra»)",
    "placeholder": "p. ej., CAD, CHF"
  },
  "total_paid_amount": {
    "prompt": "Importe total pagado",
    "placeholder": "5000"
  },
  "cost_model": {
    "prompt": "¿Cómo se estructuró el precio?",
    "options": {
      "per_graft": "Por injerto",
      "per_session": "Por sesión",
      "package": "Paquete cerrado",
      "not_clear": "No quedó claro"
    }
  },
  "what_included": {
    "prompt": "¿Qué se incluyó?",
    "options": {
      "procedure": "Intervención",
      "medications": "Medicación",
      "followup": "Seguimiento",
      "prp": "PRP",
      "accommodation": "Alojamiento",
      "transport": "Transporte",
      "other": "Otro"
    }
  },
  "what_included_other": {
    "prompt": "Otras inclusiones (especifique)"
  },
  "pain_level": {
    "prompt": "Nivel de dolor durante la cirugía",
    "help": "1 = sin dolor · 10 = dolor intenso"
  },
  "post_op_swelling": {
    "prompt": "Hinchazón postoperatoria"
  },
  "bleeding_issue": {
    "prompt": "¿Hubo sangrado importante?"
  },
  "recovery_time": {
    "prompt": "Tiempo de recuperación"
  },
  "shock_loss": {
    "prompt": "¿Experimentó caída reactiva postoperatoria (efluvio telógeno)?"
  },
  "complications": {
    "prompt": "¿Alguna complicación?"
  },
  "complications_details": {
    "prompt": "Detalle de la complicación",
    "placeholder": "Describa qué ocurrió"
  },
  "months_since": {
    "prompt": "Meses transcurridos desde el procedimiento"
  },
  "density_satisfaction": {
    "prompt": "Satisfacción con la densidad",
    "help": "(1 = muy insatisfecho/a · 5 = muy satisfecho/a)"
  },
  "hairline_naturalness": {
    "prompt": "Naturalidad de la línea frontal",
    "help": "1 = poco natural · 5 = muy natural"
  },
  "donor_appearance": {
    "prompt": "Apariencia de la zona donante",
    "help": "1 = poco satisfactoria · 5 = muy satisfactoria"
  },
  "would_repeat": {
    "prompt": "¿Repetiría el procedimiento con esta clínica?"
  },
  "would_recommend": {
    "prompt": "¿Recomendaría esta clínica?"
  },
  "enhanced_patient_answers": {
    "baseline": {
      "patient_age": {
        "prompt": "Edad",
        "placeholder": "p. ej., 34"
      },
      "patient_sex": {
        "prompt": "Sexo",
        "options": {
          "Male": "Hombre",
          "Female": "Mujer",
          "Intersex": "Intersexual",
          "Prefer not to say": "Prefiero no decirlo"
        }
      },
      "smoking_status": {
        "prompt": "Tabaquismo",
        "options": {
          "No": "No",
          "Occasionally": "Ocasional",
          "Daily": "Diario"
        }
      },
      "alcohol_frequency": {
        "prompt": "Consumo de alcohol (opcional)",
        "options": {
          "Rare": "Raras veces",
          "Weekly": "Semanal",
          "Daily": "Diario"
        }
      },
      "diabetes": {
        "prompt": "Diabetes",
        "options": {
          "No": "No",
          "Type1": "Tipo 1",
          "Type2": "Tipo 2",
          "Not sure": "No estoy seguro/a"
        }
      },
      "autoimmune_conditions": {
        "prompt": "Enfermedades autoinmunes (opcional)",
        "placeholder": "p. ej., alopecia areata, lupus, psoriasis (si lo sabe)"
      },
      "thyroid_issues": {
        "prompt": "Problemas de tiroides",
        "options": {
          "No": "No",
          "Yes": "Sí",
          "Not sure": "No estoy seguro/a"
        }
      },
      "clotting_disorders": {
        "prompt": "Trastornos de la coagulación",
        "options": {
          "No": "No",
          "Yes": "Sí",
          "Not sure": "No estoy seguro/a"
        }
      },
      "blood_thinners": {
        "prompt": "Anticoagulantes (opcional)",
        "placeholder": "Nombre(s), si aplica"
      },
      "steroid_use": {
        "prompt": "Uso de corticoides (opcional)",
        "placeholder": "Si aplica (no hace falta la dosis)"
      },
      "previous_scalp_surgeries": {
        "prompt": "Cirugías previas del cuero cabelludo (opcional)",
        "placeholder": "p. ej., trasplante anterior, reducción de cuero cabelludo"
      }
    },
    "hair_biology": {
      "hair_loss_duration_years": {
        "prompt": "Antigüedad de la caída (años)",
        "placeholder": "p. ej., 6"
      },
      "hair_loss_progression_speed": {
        "prompt": "Velocidad de progresión",
        "options": {
          "Slow": "Lenta",
          "Moderate": "Moderada",
          "Rapid": "Rápida"
        }
      },
      "family_history_strength": {
        "prompt": "Importancia de los antecedentes familiares",
        "options": {
          "None": "Ninguno",
          "Mild": "Leve",
          "Strong": "Marcada",
          "Unknown": "No lo sé"
        }
      },
      "current_medications_for_hair": {
        "prompt": "Medicación capilar actual (opcional)",
        "placeholder": "Liste lo que usa, si aplica"
      },
      "stopped_medications_recently": {
        "prompt": "¿Ha suspendido recientemente medicación capilar? (opcional)"
      },
      "scalp_condition_history": {
        "prompt": "Antecedentes del cuero cabelludo (opcional)",
        "placeholder": "p. ej., dermatitis, foliculitis, picor"
      },
      "previous_prp_or_exosomes": {
        "prompt": "¿Tratamientos previos con PRP o exosomas? (opcional)"
      }
    },
    "procedure_execution": {
      "technician_role_extraction": {
        "prompt": "¿Quién realizó la extracción?",
        "options": {
          "Doctor": "Médico",
          "Technician": "Técnico",
          "Mixed": "Mixto",
          "Not sure": "No estoy seguro/a"
        }
      },
      "technician_role_implantation": {
        "prompt": "¿Quién realizó la implantación?",
        "options": {
          "Doctor": "Médico",
          "Technician": "Técnico",
          "Mixed": "Mixto",
          "Not sure": "No estoy seguro/a"
        }
      },
      "grafts_claimed_total": {
        "prompt": "Injertos según la clínica (total, opcional)",
        "placeholder": "p. ej., 3800"
      },
      "graft_ratio": {
        "prompt": "Ratio o reparto frontal/coronilla (opcional)",
        "placeholder": "Si se lo indicaron"
      },
      "hairline_drawn_by_doctor": {
        "prompt": "¿Diseñó el médico la línea frontal?",
        "options": {
          "Yes": "Sí",
          "Technician": "Técnico",
          "Not sure": "No estoy seguro/a"
        }
      },
      "single_hair_grafts_front": {
        "prompt": "¿Se usaron injertos unifoliculares en la zona frontal?",
        "options": {
          "Yes": "Sí",
          "No": "No",
          "Not sure": "No estoy seguro/a"
        }
      },
      "crown_pattern_discussed": {
        "prompt": "¿Comentaron el diseño de la coronilla (si trabajaron la coronilla)?",
        "options": {
          "Yes": "Sí",
          "No": "No",
          "Not sure": "No estoy seguro/a"
        }
      }
    },
    "donor_profile": {
      "pre_existing_donor_thinning": {
        "prompt": "Rarefacción previa de la zona donante",
        "options": {
          "None": "Ninguna",
          "Mild": "Leve",
          "Moderate": "Moderada",
          "Severe": "Marcada",
          "Not sure": "No estoy seguro/a"
        }
      },
      "donor_density_measured": {
        "prompt": "¿Midieron la densidad capilar del donante?",
        "options": {
          "Numeric": "Sí (medición numérica)",
          "Visual only": "Solo valoración visual",
          "No": "No",
          "Not sure": "No estoy seguro/a"
        }
      },
      "donor_area_marked_preop": {
        "prompt": "¿Delimitaron la zona donante antes de la cirugía?",
        "options": {
          "Yes": "Sí",
          "No": "No",
          "Not sure": "No estoy seguro/a"
        }
      },
      "donor_extraction_pattern_observed": {
        "prompt": "Patrón de extracción observado (opcional)",
