          "4h+": "Más de 4 horas",
          "Not sure": "No estoy seguro/a"
        }
      },
      "storage_solution": {
        "prompt": "Solución de conservación (opcional)",
        "options": {
          "Saline": "Solución salina",
          "HypoThermosol": "HypoThermosol",
          "PRP": "PRP",
          "Other": "Otra",
          "Not sure": "No estoy seguro/a"
        }
      },
      "temperature_control": {
        "prompt": "Control de temperatura (opcional)",
        "options": {
          "Chilled": "Refrigerado",
          "Room temp": "Temperatura ambiente",
          "Not sure": "No estoy seguro/a"
        }
      },
      "grafts_kept_hydrated": {
        "prompt": "¿Mantuvieron los injertos hidratados? (opcional)",
        "options": {
          "Yes": "Sí",
          "No": "No",
          "Not sure": "No estoy seguro/a"
        }
      },
      "exposed_to_air": {
        "prompt": "Exposición al aire (opcional)",
        "options": {
          "Never": "Nunca",
          "Occasionally": "Ocasionalmente",
          "Frequently": "Con frecuencia",
          "Not sure": "No estoy seguro/a"
        }
      },
      "long_breaks_during_surgery": {
        "prompt": "¿Hubo pausas prolongadas durante la cirugía? (opcional)",
        "options": {
          "No": "No",
          "Under 30min": "Menos de 30 minutos",
          "Over 1h": "Más de 1 hora",
          "Not sure": "No estoy seguro/a"
        }
      }
    },
    "healing_course": {
      "current_month_postop": {
        "prompt": "Mes actual tras la cirugía (opcional)",
