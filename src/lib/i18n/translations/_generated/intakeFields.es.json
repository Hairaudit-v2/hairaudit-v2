{
  "clinic_name": {
    "prompt": "Nombre de la clínica",
    "placeholder": "ABC Hair Clinic"
  },
  "clinic_country": {
    "prompt": "País de la clínica"
  },
  "clinic_country_other": {
    "prompt": "País de la clínica (si es otro)",
    "placeholder": "por ejemplo, Portugal"
  },
  "clinic_city": {
    "prompt": "Ciudad de la clínica",
    "placeholder": "Estambul"
  },
  "procedure_date": {
    "prompt": "Fecha del procedimiento"
  },
  "procedure_type": {
    "prompt": "Tipo de procedimiento",
    "help": "Elija lo que le dijeron; 'No estoy seguro' está bien."
  },
  "procedure_type_other": {
    "prompt": "Tipo de procedimiento (si es otro)",
    "placeholder": "por ejemplo, combinado"
  },
  "surgeon_name": {
    "prompt": "Nombre del cirujano (opcional)",
    "placeholder": "Dr. Smith"
  },
  "patient_name": {
    "prompt": "Su nombre (opcional, por privacidad)",
    "placeholder": "John Doe"
  },
  "preop_consult": {
    "prompt": "¿Tuvo una consulta preoperatoria?"
  },
  "doctor_present_extraction": {
    "prompt": "¿Estaba presente un médico durante la extracción del injerto?",
    "options": {
      "yes": "Sí",
      "no": "No",
      "not_sure": "No estoy seguro/a"
    }
  },
  "doctor_present_implant": {
    "prompt": "¿Estaba presente un médico durante la implantación del injerto?",
    "options": {
      "yes": "Sí",
      "no": "No",
      "not_sure": "No estoy seguro/a"
    }
  },
  "graft_number_disclosed": {
    "prompt": "¿Le dijeron el recuento de injertos?"
  },
  "graft_number_received": {
    "prompt": "Número de injerto (si se le dio uno)",
    "help": "Solo si le indicaron un número.",
    "placeholder": "por ejemplo, 3500"
  },
  "donor_shaving": {
    "prompt": "Afeitado de la zona donante"
  },
  "surgery_duration": {
    "prompt": "Duración de la cirugía"
  },
  "total_paid_currency": {
    "prompt": "Moneda",
    "options": {
      "usd": "USD ($)",
      "eur": "EUR (€)",
      "gbp": "GBP (£)",
      "try": "TRY",
      "inr": "INR",
      "thb": "THB",
      "mxn": "MXN ($)",
      "aud": "AUD ($)",
      "other": "Otros"
    }
  },
  "total_paid_currency_other": {
    "prompt": "Moneda (si es otra)",
    "placeholder": "por ejemplo, CAD, CHF"
  },
  "total_paid_amount": {
    "prompt": "Importe total pagado",
    "placeholder": "5000"
  },
  "cost_model": {
    "prompt": "¿Cómo estaba estructurado el coste?",
    "options": {
      "per_graft": "Por injerto",
      "per_session": "Por período de sesiones",
      "package": "Paquete",
      "not_clear": "Cifra imprecisa"
    }
  },
  "what_included": {
    "prompt": "¿Qué se incluyó?",
    "options": {
      "procedure": "Procedimiento",
      "medications": "Medicamentos",
      "followup": "Seguimiento",
      "prp": "PRP*",
      "accommodation": "Alojamiento",
      "transport": "Transporte",
      "other": "Otros"
    }
  },
  "what_included_other": {
    "prompt": "Otro (especifique)"
  },
  "pain_level": {
    "prompt": "Nivel de dolor durante la cirugía",
    "help": "1 = Sin dolor, 10 = Dolor intenso"
  },
  "post_op_swelling": {
    "prompt": "Hinchazón postoperatoria"
  },
  "bleeding_issue": {
    "prompt": "sangrado significativo."
  },
  "recovery_time": {
    "prompt": "Tiempo de recuperación"
  },
  "shock_loss": {
    "prompt": "¿Experimentó pérdida por choque (desprendimiento temporal)?"
  },
  "complications": {
    "prompt": "Cualquier tipo de complicaciones."
  },
  "complications_details": {
    "prompt": "Detalles de la complicación",
    "placeholder": "Describa qué ocurrió"
  },
  "months_since": {
    "prompt": "Meses desde el procedimiento"
  },
  "density_satisfaction": {
    "prompt": "Satisfacción con la densidad",
    "help": "(1= muy insatisfecho/a, 5=muy satisfecho/a)"
  },
  "hairline_naturalness": {
    "prompt": "Naturalidad de la línea capilar",
    "help": "1 escaso - 5 excelente"
  },
  "donor_appearance": {
    "prompt": "Apariencia del área donante",
    "help": "1 escaso - 5 excelente"
  },
  "would_repeat": {
    "prompt": "¿Repetiría el procedimiento con esta clínica?"
  },
  "would_recommend": {
    "prompt": "¿Recomendaría esta clínica?"
  },
